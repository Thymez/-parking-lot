import { useEffect, useRef, useState } from 'react';
import { vehicleApi } from '../lib/api';

export default function MapView({ vehicles, selectedLot, parkingLots }) {
  const canvasRef = useRef(null);
  const [scale, setScale] = useState(1);
  const [offset, setOffset] = useState({ x: 0, y: 0 });
  const [isDragging, setIsDragging] = useState(false);
  const [dragStart, setDragStart] = useState({ x: 0, y: 0 });
  const [selectedVehicle, setSelectedVehicle] = useState(null);
  const [isDraggingVehicle, setIsDraggingVehicle] = useState(false);
  const [isRotating, setIsRotating] = useState(false);
  const [searchQuery, setSearchQuery] = useState('');
  const [showVehicleList, setShowVehicleList] = useState(false);
  const [showUnplacedVehicles, setShowUnplacedVehicles] = useState(true);
  const [lastClickTime, setLastClickTime] = useState(0);
  const [lastClickedVehicle, setLastClickedVehicle] = useState(null);
  const [draggingFromList, setDraggingFromList] = useState(null);

  const CAR_WIDTH = 40;
  const CAR_HEIGHT = 80;
  const ROTATION_HANDLE_DISTANCE = 60;

  const getLotStats = (lotNumber) => {
    const lotVehicles = vehicles.filter(v => v.parking_lot_number === lotNumber);
    const placedVehicles = lotVehicles.filter(v => v.x !== null && v.x !== undefined && v.y !== null && v.y !== undefined);
    return {
      total: lotVehicles.length,
      placed: placedVehicles.length,
      unplaced: lotVehicles.length - placedVehicles.length
    };
  };

  const navigateToVehicle = (vehicle) => {
    if (vehicle.x !== null && vehicle.x !== undefined && vehicle.y !== null && vehicle.y !== undefined) {
      const canvas = canvasRef.current;
      const centerX = canvas.width / 2;
      const centerY = canvas.height / 2;
      
      setOffset({
        x: centerX - vehicle.x * scale,
        y: centerY - vehicle.y * scale
      });
      setSelectedVehicle(vehicle);
    }
  };

  useEffect(() => {
    drawCanvas();
  }, [vehicles, selectedLot, scale, offset, selectedVehicle]);

  const getVehicleColor = (color) => {
    const colorMap = {
      'ขาว': '#FFFFFF',
      'ดำ': '#000000',
      'เทา': '#808080',
      'เงิน': '#C0C0C0',
      'แดง': '#FF0000',
      'น้ำเงิน': '#0000FF',
      'เขียว': '#00FF00',
      'เหลือง': '#FFFF00',
      'ส้ม': '#FFA500',
      'ชมพู': '#FFC0CB',
      'น้ำตาล': '#8B4513',
      'ทอง': '#FFD700',
      'ม่วง': '#800080'
    };
    return colorMap[color] || '#3B82F6';
  };

  const drawCanvas = () => {
    const canvas = canvasRef.current;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width;
    canvas.height = rect.height;

    ctx.fillStyle = '#F3F4F6';
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    const gridSize = 50 * scale;
    ctx.strokeStyle = '#E5E7EB';
    ctx.lineWidth = 1;

    for (let x = offset.x % gridSize; x < canvas.width; x += gridSize) {
      ctx.beginPath();
      ctx.moveTo(x, 0);
      ctx.lineTo(x, canvas.height);
      ctx.stroke();
    }

    for (let y = offset.y % gridSize; y < canvas.height; y += gridSize) {
      ctx.beginPath();
      ctx.moveTo(0, y);
      ctx.lineTo(canvas.width, y);
      ctx.stroke();
    }

    placedVehiclesInLot.forEach(vehicle => {
      drawVehicle(ctx, vehicle, vehicle.id === selectedVehicle?.id);
    });
  };

  const drawVehicle = (ctx, vehicle, isSelected) => {
    const x = vehicle.x * scale + offset.x;
    const y = vehicle.y * scale + offset.y;
    const rotation = (vehicle.rotation || 0) * Math.PI / 180;

    ctx.save();
    ctx.translate(x, y);
    ctx.rotate(rotation);

    const carColor = getVehicleColor(vehicle.color);
    
    ctx.fillStyle = carColor;
    ctx.strokeStyle = '#1F2937';
    ctx.lineWidth = 2;
    
    ctx.fillRect(-CAR_WIDTH / 2, -CAR_HEIGHT / 2, CAR_WIDTH, CAR_HEIGHT);
    ctx.strokeRect(-CAR_WIDTH / 2, -CAR_HEIGHT / 2, CAR_WIDTH, CAR_HEIGHT);

    ctx.fillStyle = '#60A5FA';
    ctx.fillRect(-CAR_WIDTH / 2 + 5, -CAR_HEIGHT / 2 + 5, CAR_WIDTH - 10, 15);

    ctx.fillStyle = '#1F2937';
    ctx.font = '10px Arial';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    const plateText = vehicle.license_plate || 'N/A';
    ctx.fillText(plateText, 0, 0);

    if (isSelected) {
      ctx.strokeStyle = '#3B82F6';
      ctx.lineWidth = 3;
      const padding = 10;
      ctx.strokeRect(
        -CAR_WIDTH / 2 - padding,
        -CAR_HEIGHT / 2 - padding,
        CAR_WIDTH + padding * 2,
        CAR_HEIGHT + padding * 2
      );

      ctx.fillStyle = '#3B82F6';
      const handleSize = 8;
      const corners = [
        [-CAR_WIDTH / 2 - padding, -CAR_HEIGHT / 2 - padding],
        [CAR_WIDTH / 2 + padding, -CAR_HEIGHT / 2 - padding],
        [CAR_WIDTH / 2 + padding, CAR_HEIGHT / 2 + padding],
        [-CAR_WIDTH / 2 - padding, CAR_HEIGHT / 2 + padding]
      ];
      
      corners.forEach(([cx, cy]) => {
        ctx.fillRect(cx - handleSize / 2, cy - handleSize / 2, handleSize, handleSize);
      });

      ctx.beginPath();
      ctx.arc(0, -ROTATION_HANDLE_DISTANCE, 6, 0, Math.PI * 2);
      ctx.fillStyle = '#10B981';
      ctx.fill();
      ctx.strokeStyle = '#FFFFFF';
      ctx.lineWidth = 2;
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(0, -CAR_HEIGHT / 2 - padding);
      ctx.lineTo(0, -ROTATION_HANDLE_DISTANCE);
      ctx.strokeStyle = '#10B981';
      ctx.lineWidth = 2;
      ctx.stroke();
    }

    ctx.restore();
  };

  const getMousePos = (e) => {
    const canvas = canvasRef.current;
    const rect = canvas.getBoundingClientRect();
    return {
      x: e.clientX - rect.left,
      y: e.clientY - rect.top
    };
  };

  const getVehicleAtPos = (mouseX, mouseY) => {
    const filteredVehicles = vehicles.filter(v => 
      (!selectedLot || v.parking_lot_number === selectedLot) &&
      v.x !== undefined && v.y !== undefined
    );

    for (let i = filteredVehicles.length - 1; i >= 0; i--) {
      const vehicle = filteredVehicles[i];
      const x = vehicle.x * scale + offset.x;
      const y = vehicle.y * scale + offset.y;
      const rotation = (vehicle.rotation || 0) * Math.PI / 180;

      const dx = mouseX - x;
      const dy = mouseY - y;
      const rotatedX = dx * Math.cos(-rotation) - dy * Math.sin(-rotation);
      const rotatedY = dx * Math.sin(-rotation) + dy * Math.cos(-rotation);

      if (Math.abs(rotatedX) <= CAR_WIDTH / 2 && Math.abs(rotatedY) <= CAR_HEIGHT / 2) {
        return vehicle;
      }
    }
    return null;
  };

  const isNearRotationHandle = (mouseX, mouseY, vehicle) => {
    if (!vehicle) return false;
    
    const x = vehicle.x * scale + offset.x;
    const y = vehicle.y * scale + offset.y;
    const rotation = (vehicle.rotation || 0) * Math.PI / 180;

    const handleX = x + Math.sin(rotation) * -ROTATION_HANDLE_DISTANCE;
    const handleY = y + Math.cos(rotation) * -ROTATION_HANDLE_DISTANCE;

    const distance = Math.sqrt(Math.pow(mouseX - handleX, 2) + Math.pow(mouseY - handleY, 2));
    return distance <= 15;
  };

  const handleMouseDown = (e) => {
    const pos = getMousePos(e);
    const vehicle = getVehicleAtPos(pos.x, pos.y);

    if (draggingFromList) {
      const canvasX = (pos.x - offset.x) / scale;
      const canvasY = (pos.y - offset.y) / scale;
      
      vehicleApi.updatePosition(draggingFromList.id, {
        x: canvasX,
        y: canvasY,
        rotation: 0
      }).catch(console.error);
      
      setDraggingFromList(null);
      return;
    }

    if (vehicle) {
      const currentTime = Date.now();
      const timeDiff = currentTime - lastClickTime;
      
      if (timeDiff < 300 && lastClickedVehicle?.id === vehicle.id) {
        navigateToVehicle(vehicle);
        setLastClickTime(0);
        setLastClickedVehicle(null);
        return;
      }
      
      setLastClickTime(currentTime);
      setLastClickedVehicle(vehicle);
      
      if (isNearRotationHandle(pos.x, pos.y, vehicle)) {
        setIsRotating(true);
        setSelectedVehicle(vehicle);
      } else {
        setIsDraggingVehicle(true);
        setSelectedVehicle(vehicle);
        setDragStart({ 
          x: pos.x - vehicle.x * scale - offset.x, 
          y: pos.y - vehicle.y * scale - offset.y 
        });
      }
    } else {
      setIsDragging(true);
      setDragStart({ x: pos.x - offset.x, y: pos.y - offset.y });
      setSelectedVehicle(null);
    }
  };

  const handleMouseMove = (e) => {
    const pos = getMousePos(e);

    if (isRotating && selectedVehicle) {
      const vehicleX = selectedVehicle.x * scale + offset.x;
      const vehicleY = selectedVehicle.y * scale + offset.y;
      const angle = Math.atan2(pos.x - vehicleX, -(pos.y - vehicleY)) * 180 / Math.PI;
      
      const updatedVehicle = { ...selectedVehicle, rotation: Math.round(angle) };
      setSelectedVehicle(updatedVehicle);
      
      vehicleApi.updatePosition(selectedVehicle.id, {
        x: selectedVehicle.x,
        y: selectedVehicle.y,
        rotation: Math.round(angle)
      }).catch(console.error);
    } else if (isDraggingVehicle && selectedVehicle) {
      const newX = (pos.x - offset.x - dragStart.x) / scale;
      const newY = (pos.y - offset.y - dragStart.y) / scale;
      
      const updatedVehicle = { ...selectedVehicle, x: newX, y: newY };
      setSelectedVehicle(updatedVehicle);
    } else if (isDragging) {
      setOffset({
        x: pos.x - dragStart.x,
        y: pos.y - dragStart.y
      });
    }
  };

  const handleMouseUp = async () => {
    if (isDraggingVehicle && selectedVehicle) {
      try {
        await vehicleApi.updatePosition(selectedVehicle.id, {
          x: selectedVehicle.x,
          y: selectedVehicle.y,
          rotation: selectedVehicle.rotation || 0
        });
      } catch (error) {
        console.error('Failed to update position:', error);
      }
    }
    
    setIsDragging(false);
    setIsDraggingVehicle(false);
    setIsRotating(false);
  };

  const handleWheel = (e) => {
    e.preventDefault();
    const delta = e.deltaY > 0 ? 0.9 : 1.1;
    const newScale = Math.max(0.5, Math.min(3, scale * delta));
    setScale(newScale);
  };

  const filteredVehiclesByLot = vehicles.filter(v => 
    !selectedLot || v.parking_lot_number === selectedLot
  );

  const allVehiclesForList = vehicles.map(v => ({
    ...v,
    isPlaced: v.x !== null && v.x !== undefined && v.y !== null && v.y !== undefined
  })).filter(v => {
    if (!searchQuery.trim()) return true;
    return v.license_plate?.toLowerCase().includes(searchQuery.toLowerCase()) ||
           v.brand?.toLowerCase().includes(searchQuery.toLowerCase()) ||
           v.model?.toLowerCase().includes(searchQuery.toLowerCase()) ||
           v.zone?.toLowerCase().includes(searchQuery.toLowerCase());
  });

  const unplacedVehiclesInLot = filteredVehiclesByLot.filter(v => 
    v.x === null || v.x === undefined || v.y === null || v.y === undefined
  );

  const placedVehiclesInLot = filteredVehiclesByLot.filter(v => 
    v.x !== null && v.x !== undefined && v.y !== null && v.y !== undefined
  );

  return (
    <div className="bg-white rounded-lg shadow-lg h-[calc(100vh-250px)] flex flex-col">
      <div className="p-2 sm:p-4 border-b border-gray-200">
        <div className="flex flex-col gap-2">
          <div className="flex gap-2">
            <input
              type="text"
              placeholder="ค้นหารถ..."
              value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
              className="flex-1 px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none"
            />
            <button
              onClick={() => setShowVehicleList(!showVehicleList)}
              className={`px-3 py-2 rounded-lg font-medium transition text-sm whitespace-nowrap ${
                showVehicleList 
                  ? 'bg-blue-500 text-white' 
                  : 'bg-gray-100 hover:bg-gray-200 text-gray-700'
              }`}
            >
              <svg className="w-4 h-4 inline sm:mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4 6h16M4 10h16M4 14h16M4 18h16" />
              </svg>
              <span className="hidden sm:inline">ทั้งหมด ({allVehiclesForList.length})</span>
            </button>
            <button
              onClick={() => setShowUnplacedVehicles(!showUnplacedVehicles)}
              className={`px-3 py-2 rounded-lg font-medium transition text-sm whitespace-nowrap ${
                showUnplacedVehicles 
                  ? 'bg-orange-500 text-white' 
                  : 'bg-gray-100 hover:bg-gray-200 text-gray-700'
              }`}
            >
              <svg className="w-4 h-4 inline sm:mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 4v16m8-8H4" />
              </svg>
              <span className="hidden sm:inline">ยังไม่วาง ({unplacedVehiclesInLot.length})</span>
            </button>
          </div>
          
          <div className="flex gap-2">
            <button
              onClick={() => setScale(Math.min(3, scale * 1.2))}
              className="px-3 py-2 bg-gray-100 hover:bg-gray-200 rounded-lg transition"
              title="ซูมเข้า"
            >
              <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v6m3-3H7" />
              </svg>
            </button>
            <button
              onClick={() => setScale(Math.max(0.5, scale * 0.8))}
              className="px-3 py-2 bg-gray-100 hover:bg-gray-200 rounded-lg transition"
              title="ซูมออก"
            >
              <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM13 10H7" />
              </svg>
            </button>
            <button
              onClick={() => { setScale(1); setOffset({ x: 0, y: 0 }); }}
              className="px-3 py-2 bg-gray-100 hover:bg-gray-200 rounded-lg transition"
              title="รีเซ็ต"
            >
              <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
            </button>
          </div>
        </div>

      </div>

      <div className="flex-1 relative flex flex-col sm:flex-row overflow-hidden">
        {showUnplacedVehicles && unplacedVehiclesInLot.length > 0 && (
          <div className="w-full sm:w-64 border-b sm:border-b-0 sm:border-r border-gray-200 bg-gradient-to-br from-orange-50 to-yellow-50 overflow-y-auto max-h-40 sm:max-h-full flex-shrink-0">
            <div className="p-2 sm:p-3">
              <div className="flex items-center justify-between mb-2">
                <h3 className="font-bold text-xs sm:text-sm text-orange-800">
                  รถที่ยังไม่วาง ({unplacedVehiclesInLot.length})
                </h3>
                <button
                  onClick={() => setShowUnplacedVehicles(false)}
                  className="text-gray-500 hover:text-gray-700 p-1"
                >
                  <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>
              <p className="text-xs text-orange-700 mb-2">
                คลิกรถ → คลิกแผนที่เพื่อวาง
              </p>
              <div className="grid grid-cols-2 sm:grid-cols-1 gap-2">
                {unplacedVehiclesInLot.map(vehicle => (
                  <div
                    key={vehicle.id}
                    onClick={() => setDraggingFromList(vehicle)}
                    className={`p-2 rounded-lg cursor-pointer transition shadow-sm ${
                      draggingFromList?.id === vehicle.id
                        ? 'bg-orange-500 text-white ring-2 ring-orange-600'
                        : 'bg-white hover:bg-orange-100 text-gray-800'
                    }`}
                  >
                    <div className="font-semibold text-xs sm:text-sm truncate">
                      {vehicle.license_plate}
                    </div>
                    <div className="text-xs opacity-75 truncate">
                      {vehicle.brand} {vehicle.model}
                    </div>
                    <div className="text-xs opacity-60 truncate">
                      {vehicle.zone}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}

        {showVehicleList && (
          <div className="hidden sm:block w-80 border-r border-gray-200 bg-gray-50 overflow-y-auto">
            <div className="p-4">
              <h3 className="font-bold text-lg mb-4">รายการรถทั้งหมด</h3>
              
              {parkingLots.map(lot => {
                const stats = getLotStats(lot.parking_lot_number);
                const lotVehicles = allVehiclesForList.filter(v => v.parking_lot_number === lot.parking_lot_number);
                
                if (lotVehicles.length === 0) return null;
                
                return (
                  <div key={lot.parking_lot_number} className="mb-4">
                    <div className="bg-white rounded-lg p-3 mb-2 shadow-sm">
                      <div className="flex justify-between items-center">
                        <h4 className="font-semibold text-gray-800">
                          ลาน {lot.parking_lot_number}: {lot.parking_lot_name}
                        </h4>
                      </div>
                      <div className="mt-2 flex gap-4 text-sm">
                        <span className="text-gray-600">
                          ทั้งหมด: <span className="font-semibold text-blue-600">{stats.total}</span>
                        </span>
                        <span className="text-gray-600">
                          วางแล้ว: <span className="font-semibold text-green-600">{stats.placed}</span>
                        </span>
                        <span className="text-gray-600">
                          ยังไม่วาง: <span className="font-semibold text-orange-600">{stats.unplaced}</span>
                        </span>
                      </div>
                    </div>
                    
                    <div className="space-y-1">
                      {lotVehicles.map(vehicle => (
                        <div
                          key={vehicle.id}
                          onDoubleClick={() => {
                            if (vehicle.isPlaced) {
                              navigateToVehicle(vehicle);
                              setShowVehicleList(false);
                            }
                          }}
                          className={`p-2 rounded cursor-pointer transition ${
                            selectedVehicle?.id === vehicle.id 
                              ? 'bg-blue-100 border border-blue-300' 
                              : 'bg-white hover:bg-gray-100'
                          }`}
                        >
                          <div className="flex justify-between items-start">
                            <div className="flex-1">
                              <div className="font-semibold text-blue-600 text-sm">
                                {vehicle.license_plate}
                              </div>
                              <div className="text-xs text-gray-600">
                                {vehicle.brand} {vehicle.model} - {vehicle.zone}
                              </div>
                            </div>
                            <div className="text-xs">
                              {vehicle.isPlaced ? (
                                <span className="text-green-600 font-semibold">● วางแล้ว</span>
                              ) : (
                                <span className="text-orange-600">○ ยังไม่วาง</span>
                              )}
                            </div>
                          </div>
                          {vehicle.isPlaced && (
                            <div className="text-xs text-gray-400 mt-1">
                              Double-click เพื่อไปที่ตำแหน่ง
                            </div>
                          )}
                        </div>
                      ))}
                    </div>
                  </div>
                );
              })}
              
              {allVehiclesForList.length === 0 && (
                <div className="text-center text-gray-500 py-8">
                  ไม่พบรถที่ค้นหา
                </div>
              )}
            </div>
          </div>
        )}

        <div className="flex-1 relative">
          <canvas
            ref={canvasRef}
            onMouseDown={handleMouseDown}
            onMouseMove={handleMouseMove}
            onMouseUp={handleMouseUp}
            onMouseLeave={handleMouseUp}
            onWheel={handleWheel}
            className="w-full h-full cursor-move"
          />

          {draggingFromList && (
            <div className="absolute inset-0 bg-blue-500 bg-opacity-10 flex items-center justify-center z-10">
              <div className="bg-white rounded-lg shadow-xl p-3 sm:p-6 text-center max-w-xs">
                <svg className="w-10 h-10 sm:w-16 sm:h-16 mx-auto mb-2 sm:mb-3 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <p className="text-sm sm:text-lg font-bold text-gray-800 mb-1">
                  {draggingFromList.license_plate}
                </p>
                <p className="text-xs sm:text-sm text-gray-600">
                  แตะบนแผนที่เพื่อวางรถ
                </p>
                <button
                  onClick={(e) => {
                    e.stopPropagation();
                    setDraggingFromList(null);
                  }}
                  className="mt-2 px-3 py-1 bg-gray-200 hover:bg-gray-300 rounded text-xs sm:text-sm"
                >
                  ยกเลิก
                </button>
              </div>
            </div>
          )}

          {selectedVehicle && !showVehicleList && !draggingFromList && (
            <div className="absolute bottom-2 left-2 sm:bottom-4 sm:left-4 bg-white rounded-lg shadow-lg p-2 sm:p-4 max-w-xs sm:max-w-sm text-xs sm:text-sm">
              <h3 className="font-bold text-sm sm:text-lg mb-1 sm:mb-2">ข้อมูลรถ</h3>
              <div className="space-y-0.5 sm:space-y-1">
                <p><span className="font-semibold">ทะเบียน:</span> {selectedVehicle.license_plate}</p>
                <p><span className="font-semibold">ยี่ห้อ:</span> {selectedVehicle.brand} {selectedVehicle.model}</p>
                <p><span className="font-semibold">สี:</span> {selectedVehicle.color}</p>
                <p className="hidden sm:block"><span className="font-semibold">ลาน:</span> {selectedVehicle.parking_lot_number} - {selectedVehicle.parking_lot_name}</p>
                <p><span className="font-semibold">โซน:</span> {selectedVehicle.zone}</p>
                <p><span className="font-semibold">มุม:</span> {selectedVehicle.rotation || 0}°</p>
              </div>
            </div>
          )}

          {selectedLot && !draggingFromList && (
            <div className="absolute top-2 left-2 sm:top-4 sm:left-4 bg-white rounded-lg shadow-lg p-2 sm:p-3 text-xs sm:text-sm">
              <p className="font-semibold text-gray-800 mb-1 sm:mb-2">
                ลาน {selectedLot}: {parkingLots.find(l => l.parking_lot_number === selectedLot)?.parking_lot_name}
              </p>
              {(() => {
                const stats = getLotStats(selectedLot);
                return (
                  <div className="space-y-0.5 sm:space-y-1">
                    <p className="text-gray-600">
                      ทั้งหมด: <span className="font-semibold text-blue-600">{stats.total}</span>
                    </p>
                    <p className="text-gray-600">
                      วางแล้ว: <span className="font-semibold text-green-600">{stats.placed}</span>
                    </p>
                    <p className="text-gray-600">
                      ยังไม่วาง: <span className="font-semibold text-orange-600">{stats.unplaced}</span>
                    </p>
                  </div>
                );
              })()}
            </div>
          )}

          <div className="hidden sm:block absolute top-4 right-4 bg-white rounded-lg shadow-lg p-3">
            <div className="text-sm space-y-2">
              <p className="font-semibold">คำแนะนำ:</p>
              <p>• คลิกรถที่ยังไม่วางแล้วคลิกบนแผนที่</p>
              <p>• ลากรถเพื่อย้ายตำแหน่ง</p>
              <p>• ใช้จุดสีเขียวเพื่อหมุนรถ</p>
              <p>• Double-click รถเพื่อโฟกัส</p>
              <p>• ลากพื้นที่ว่างเพื่อเลื่อนแผนที่</p>
              <p className="text-xs text-gray-500 mt-2">
                ซูม: {Math.round(scale * 100)}%
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
