    "cookie": "0.6.0",
    "cors": "2.8.5",
    "dotenv": "^17.2.3",
    "express": "4.18.2",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "9.0.2",
    "lucide-react": "^0.577.0",
    "multer": "^2.0.2",
    "next": "13.5.6",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-resizable-panels": "^4.7.3",
    "resize-observer-polyfill": "^1.5.1",
    "socket.io": "4.6.2",
    "socket.io-client": "4.6.2",
